    "chart.js": "^4.5.1",
    "json-server": "^1.0.0-beta.15",
    "ngx-toastr": "^20.0.5",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.24",
    "tslib": "^2.3.0"
